		TeethPeriod = (int)8;
		TeethShift = (int)5;
		LipsPeriod = (int)5;
		LipsShift = (int)3;
		MAmethod = (ENUM_MA_METHOD)MODE_SMMA;
		AppliedPrice = (ENUM_APPLIED_PRICE)PRICE_CLOSE;
