//^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^//
int OnInit()
{

	// Initiate Constants
	c::Doji_ON_OFF = Doji_ON_OFF;
	c::Doji_Wick_Percent = Doji_Wick_Percent;
	c::Engulfing_ON_OFF = Engulfing_ON_OFF;
	c::Body_Engulfing_Ratio = Body_Engulfing_Ratio;
	c::Star_ON_OFF = Star_ON_OFF;
	c::Body_Star_Ratio = Body_Star_Ratio;
	c::Tower_ON_OFF = Tower_ON_OFF;
	c::Body_Tower_Ratio = Body_Tower_Ratio;
	c::ZZ_Depth = ZZ_Depth;
	c::FIBO_Level = FIBO_Level;
	c::Lot_Percent = Lot_Percent;
	c::Close_All_Percent = Close_All_Percent;
	c::Close_continous_order = Close_continous_order;
	c::Cut_Loss_Percent = Cut_Loss_Percent;
	c::Martingale_Multiple = Martingale_Multiple;
	c::Spread_Filter = Spread_Filter;
	c::Comment = Comment;
	c::Percent_START_HEDGING = Percent_START_HEDGING;
	c::Max_LOT = Max_LOT;
	c::Candle = Candle;
	c::Lot_Divided = Lot_Divided;
	c::check_trade_count = check_trade_count;
	c::Nearby_PIP = Nearby_PIP;
	c::Dleta_para = Dleta_para;
	c::SL_PiP = SL_PiP;
	c::Time_pass_onec = Time_pass_onec;
	c::pip_to_fall_rise = pip_to_fall_rise;
	c::no_candle_fall_rise = no_candle_fall_rise;
	c::Hedge_Multiplier = Hedge_Multiplier;
	c::BE = BE;
	c::BE_profit = BE_profit;
	c::Max_Lot = Max_Lot;
	c::Max_Trede = Max_Trede;
	c::Pull_Back = Pull_Back;
	c::BIG_TF = BIG_TF;
	c::MEDIUM_TF = MEDIUM_TF;
	c::SMALL_TF = SMALL_TF;
	c::_1_STO_K = _1_STO_K;
	c::_1_STO_D = _1_STO_D;
	c::_1_STO_Slow = _1_STO_Slow;
	c::_2_MACD_Fast = _2_MACD_Fast;
	c::_2_MACD_Slow = _2_MACD_Slow;
	c::_2_MACD_Signal = _2_MACD_Signal;
	c::_3_RSI_Period = _3_RSI_Period;
	c::_4_BB_Period = _4_BB_Period;
	c::_4_BB_Dev = _4_BB_Dev;
	c::Percent_Action = Percent_Action;
	c::Price_action_order = Price_action_order;
	c::Trailing_loss_money = Trailing_loss_money;
	c::Step_money = Step_money;
	c::Start_money = Start_money;
	c::Trailing_pip = Trailing_pip;
	c::ZZ = ZZ;
	c::CCI_Period = CCI_Period;
	c::CCI_Upper = CCI_Upper;
	c::CCI_Lower = CCI_Lower;
	c::TICK = TICK;
	c::Pip = Pip;
	c::Sec = Sec;
	c::MA1 = MA1;
	c::MA2 = MA2;
	c::Candle_2 = Candle_2;
	c::Pip_trade_more_max = Pip_trade_more_max;
	c::MagicStart = MagicStart;




	// Initiate Externs
	_externs::inp131275685_Lo_CandleID = inp131275685_Lo_CandleID;
	_externs::inp131275685_Ro_Step = inp131275685_Ro_Step;
	_externs::inp131275685_Ro_Maximum = inp131275685_Ro_Maximum;
