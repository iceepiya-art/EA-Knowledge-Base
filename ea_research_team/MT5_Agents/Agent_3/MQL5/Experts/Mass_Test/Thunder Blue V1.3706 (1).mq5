// "Set "Current Timeframe" for next blocks" model
template<typename T1,typename T2,typename T3,typename T4,typename T5,typename T6,typename T7,typename T8,typename T9,typename T10>
class MDL_SetCurrentTimeframe: public BlockCalls
{
	public: /* Input Parameters */
	T1 SetCurrentTimeframe;
	T2 SetCurrentTimeframe2;
	T3 SetCurrentTimeframe3;
	T4 SetCurrentTimeframe4;
	T5 SetCurrentTimeframe5;
	T6 SetCurrentTimeframe6;
	T7 SetCurrentTimeframe7;
	T8 SetCurrentTimeframe8;
	T9 SetCurrentTimeframe9;
	T10 SetCurrentTimeframe10;
	virtual void _callback_(int r) {return;}

	public: /* Constructor */
	MDL_SetCurrentTimeframe()
	{
		SetCurrentTimeframe = (ENUM_TIMEFRAMES)PERIOD_H1;
		SetCurrentTimeframe2 = (ENUM_TIMEFRAMES)-1;
		SetCurrentTimeframe3 = (ENUM_TIMEFRAMES)-1;
		SetCurrentTimeframe4 = (ENUM_TIMEFRAMES)-1;
		SetCurrentTimeframe5 = (ENUM_TIMEFRAMES)-1;
		SetCurrentTimeframe6 = (ENUM_TIMEFRAMES)-1;
		SetCurrentTimeframe7 = (ENUM_TIMEFRAMES)-1;
		SetCurrentTimeframe8 = (ENUM_TIMEFRAMES)-1;
		SetCurrentTimeframe9 = (ENUM_TIMEFRAMES)-1;
		SetCurrentTimeframe10 = (ENUM_TIMEFRAMES)-1;
	}

	public: /* The main method */
	virtual void _execute_()
	{
		for (int i=1; i<=10; i++)
		{
		   if (i == 1) {if (SetCurrentTimeframe >= 0) {CurrentTimeframe((ENUM_TIMEFRAMES)SetCurrentTimeframe);} else {continue;}}
		   if (i == 2) {if (SetCurrentTimeframe2 >= 0) {CurrentTimeframe((ENUM_TIMEFRAMES)SetCurrentTimeframe2);} else {continue;}}
		   if (i == 3) {if (SetCurrentTimeframe3 >= 0) {CurrentTimeframe((ENUM_TIMEFRAMES)SetCurrentTimeframe3);} else {continue;}}
		   if (i == 4) {if (SetCurrentTimeframe4 >= 0) {CurrentTimeframe((ENUM_TIMEFRAMES)SetCurrentTimeframe4);} else {continue;}}
		   if (i == 5) {if (SetCurrentTimeframe5 >= 0) {CurrentTimeframe((ENUM_TIMEFRAMES)SetCurrentTimeframe5);} else {continue;}}
		   if (i == 6) {if (SetCurrentTimeframe6 >= 0) {CurrentTimeframe((ENUM_TIMEFRAMES)SetCurrentTimeframe6);} else {continue;}}
		   if (i == 7) {if (SetCurrentTimeframe7 >= 0) {CurrentTimeframe((ENUM_TIMEFRAMES)SetCurrentTimeframe7);} else {continue;}}
		   if (i == 8) {if (SetCurrentTimeframe8 >= 0) {CurrentTimeframe((ENUM_TIMEFRAMES)SetCurrentTimeframe8);} else {continue;}}
		   if (i == 9) {if (SetCurrentTimeframe9 >= 0) {CurrentTimeframe((ENUM_TIMEFRAMES)SetCurrentTimeframe9);} else {continue;}}
		   if (i == 10) {if (SetCurrentTimeframe10 >= 0) {CurrentTimeframe((ENUM_TIMEFRAMES)SetCurrentTimeframe10);} else {break;}}
		
		   _callback_(1);
		}
		
		CurrentTimeframe(0); // Reset current timeframe
		
		_callback_(0);
	}
};

