	virtual double _Lo_() {
		Lo.Value = v::Profit_All;

		double value = (double)Lo._execute_();
		value = value*-1; // Adjust the value
		return value;
	}
	virtual double _Ro_() {
		Ro.Value = v::Percent_for_Stop;

		double value = (double)Ro._execute_();
		value = value*2; // Adjust the value
		return value;
	}

	public: /* Callback & Run */
	virtual void _callback_(int value) {
		if (value == 1) {
			_blocks_[91].run(529);
		}
	}
};

