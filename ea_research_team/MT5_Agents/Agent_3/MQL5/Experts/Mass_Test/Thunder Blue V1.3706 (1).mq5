		if (value == 1) {
			_blocks_[6].run(5);
		}
	}

	virtual void _beforeExecute_()
	{

		v::LOT_G1 = _Value1_();
		v::LOT_G2 = _Value2_();
		v::LOT_G3 = _Value3_();
		v::LOT_G4 = _Value4_();
		v::LOT_G5 = _Value5_();
	}
};

