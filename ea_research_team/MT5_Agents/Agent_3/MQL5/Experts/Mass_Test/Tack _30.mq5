// "Description (Text)" model
class MDLIC_eventChart_Description
{
	public: /* Input Parameters */
	virtual void _callback_(int r) {return;}

	public: /* Constructor */
	MDLIC_eventChart_Description()
	{
	}

	public: /* The main method */
	string _execute_()
	{
		string retval = "";
		string objname = FXD_ONCHART.sparam;
		
		if (objname == "") {retval = "";}
		else {
			retval = ObjectGetString(0, objname, OBJPROP_TEXT);
		}
		
		return(retval);
	}
};

