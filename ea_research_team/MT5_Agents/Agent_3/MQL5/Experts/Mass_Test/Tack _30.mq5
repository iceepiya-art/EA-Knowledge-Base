// Block 1573 (Custom MQL code)
class Block1569: public MDL_CustomCode<bool>
{

	public: /* Constructor */
	Block1569() {
		__block_number = 1569;
		__block_user_number = "1573";
		_beforeExecuteEnabled = true;
	}

	public: /* Callback & Run */
	virtual void _callback_(int value) {
	}

	virtual void _beforeExecute_()
	{

		double values[20];
double absValues[20];
int indexes[20];

// ใส่ค่า v::Percent_SET0 ถึง Percent_SET20
values[0] = v::Percent_SET0;
values[1] = v::Percent_SET2;
values[2] = v::Percent_SET3;
values[3] = v::Percent_SET4;
values[4] = v::Percent_SET5;
values[5] = v::Percent_SET6;
values[6] = v::Percent_SET7;
values[7] = v::Percent_SET8;
values[8] = v::Percent_SET9;
values[9] = v::Percent_SET10;
values[10] = v::Percent_SET00;
values[11] = v::Percent_SET12;
values[12] = v::Percent_SET13;
values[13] = v::Percent_SET14;
values[14] = v::Percent_SET15;
values[15] = v::Percent_SET16;
values[16] = v::Percent_SET17;
values[17] = v::Percent_SET18;
values[18] = v::Percent_SET19;
values[19] = v::Percent_SET20;

// ทำค่า absolute และ index
for(int i = 0; i < 20; i++) {
    absValues[i] = MathAbs(values[i]);
    indexes[i] = i;
}

// Bubble Sort
for(int i = 0; i < 19; i++) {
    for(int j = i + 1; j < 20; j++) {
        if(absValues[j] > absValues[i]) {
            // swap abs value
            double tmpAbs = absValues[i];
            absValues[i] = absValues[j];
            absValues[j] = tmpAbs;

            // swap index
            int tmpIdx = indexes[i];
            indexes[i] = indexes[j];
            indexes[j] = tmpIdx;
        }
    }
}

// ดึงค่าจริงจาก indexes[0] ถึง indexes[4]
int id;

id = indexes[0]; v::Top1_ID = id + 1; v::Top1_Value = values[id];
id = indexes[1]; v::Top2_ID = id + 1; v::Top2_Value = values[id];
id = indexes[2]; v::Top3_ID = id + 1; v::Top3_Value = values[id];
id = indexes[3]; v::Top4_ID = id + 1; v::Top4_Value = values[id];
id = indexes[4]; v::Top5_ID = id + 1; v::Top5_Value = values[id];
	}
};

