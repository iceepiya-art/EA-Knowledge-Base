# Copy this file to .env on each machine. Do not copy secrets between hosts.
# Workstation example when AlphaEdge is synced through Google Drive:
# CME_ALPHAEDGE_DIR="G:\My Drive\save log-blueprint-skill\AlphaEdge_CME_AUTO_ALL_EDITION_CLEAN"
# Server example with a local deployment folder:
CME_ALPHAEDGE_DIR="C:\EA-Runtime\AlphaEdge_CME_AUTO_ALL_EDITION_CLEAN"
CME_FRESHNESS_MAX_AGE_MINUTES="120"

# Select exactly one profile for the account this runtime is allowed to trade.
# FTMO_2STEP requires RISK_INITIAL_BALANCE and FTMO_DAILY_RESET_BALANCE.
# PERSONAL optionally uses PERSONAL_EQUITY_FLOOR.  Never store credentials here.
ACCOUNT_RISK_PROFILE="PERSONAL"
EXPECTED_MT5_ACCOUNT=""
RISK_INITIAL_BALANCE=""
RISK_SAFETY_BUFFER_PCT="20"
FTMO_DAILY_RESET_BALANCE=""
PERSONAL_EQUITY_FLOOR=""

# TopstepX must use its own profile and API account.  The guard blocks orders
# until all three values below are set for the selected Topstep account.
TOPSTEP_ACCOUNT_ID=""
TOPSTEP_MLL_FLOOR=""
TOPSTEP_MAX_CONTRACTS=""
